{
  "name": "fumadocs-template",
  "version": "1.0.6",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "docker:build": "IS_BUILD_DOCKER=1 npm run build",
    "docker:dev": "WATCHPACK_POLLING=true next dev"
  },
  "dependencies": {
    "fumadocs-core": "16.7.7",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.7",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
