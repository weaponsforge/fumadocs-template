{
  "name": "fumadocs-template",
  "version": "1.1.6",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "docker:webpack": "next dev --webpack",
    "docker:build": "IS_BUILD_DOCKER=1 npm run build"
  },
  "dependencies": {
    "fumadocs-core": "16.10.4",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
