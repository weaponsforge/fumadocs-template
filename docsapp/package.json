{
  "name": "fumadocs-template",
  "version": "1.0.6",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "docker:build": "IS_BUILD_DOCKER=1 npm run build",
    "docker:dev": "WATCHPACK_POLLING=true next dev"
  },
  "dependencies": {
    "fumadocs-core": "16.7.4",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.4",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
